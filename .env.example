# Altera AI — root environment example.
#
# Copy to .env (gitignored) and fill in for local dev. Each app also
# has its own .env.example with app-specific variables.

# --- Supabase (schema landed in Phase 13; Python/React wiring is the
# follow-on phase) ---
# Local Supabase via the CLI defaults to:
#   SUPABASE_URL=http://127.0.0.1:54321
#   DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# The anon + service role keys are printed by `supabase start`.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# --- AI provider (placeholder; real provider lands later) ---
# Commercial data is NEVER sent to the LLM. See
# docs/classification/ai-inputs-policy.md.
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
