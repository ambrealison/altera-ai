# apps/api — backend environment example.

# Bind address for the FastAPI dev server.
API_HOST=127.0.0.1
API_PORT=8000

# CORS — comma-separated origins the API will accept browser requests from.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Supabase project — used by the auth verifier (13C+), Postgres-backed
# store (13B), and Supabase Storage (13D). Pull from `supabase status`
# after `supabase start`, or from the Supabase dashboard.
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
# Anon/publishable key — used to create per-request JWT-scoped clients
# so Postgres RLS policies apply to data queries (Phase 14).
SUPABASE_ANON_KEY=
DATABASE_URL=

# Persistence backend. true (default) = in-memory store (dev/test).
# false = Postgres via SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY.
ALTERA_USE_IN_MEMORY_STORE=true

# JWT verification tuning (defaults are usually correct).
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ALGORITHM=HS256

# Dev auth fallback. When ALTERA_DEV_AUTH_ENABLED=true AND no
# Authorization header is present, the API returns a synthetic dev user
# scoped to the demo organisation. NEVER enable this in production.
ALTERA_DEV_AUTH_ENABLED=false
ALTERA_DEV_USER_ID=00000000-0000-0000-0000-000000000001
ALTERA_DEV_ORGANISATION_ID=00000000-0000-0000-0000-000000000010
ALTERA_DEV_USER_EMAIL=dev@altera-ai.local

# AI provider (real provider lands later).
OPENAI_API_KEY=

# Structured logging (Phase 28B).
# LOG_LEVEL accepts DEBUG, INFO, WARNING, ERROR. Default: INFO.
LOG_LEVEL=INFO

# Sentry error tracking (Phase 28B).
# Leave SENTRY_DSN empty to disable Sentry entirely.
# sentry-sdk must be installed separately: pip install sentry-sdk
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# Fraction of transactions captured for performance tracing (0.0 – 1.0).
SENTRY_TRACES_SAMPLE_RATE=0.05
