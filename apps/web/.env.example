# apps/web — frontend environment example.

# URL of the FastAPI backend. NEXT_PUBLIC_API_URL is the legacy name and
# is still accepted; NEXT_PUBLIC_API_BASE_URL is preferred.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase — used by the browser Supabase client (Phase 13C/13D).
# Pull these from `supabase status` for local dev, or from the Supabase
# dashboard for a hosted project. They are PUBLIC — never put the
# service role key here.
NEXT_PUBLIC_SUPABASE_URL=
# New Supabase branding (preferred); falls back to ANON_KEY if absent.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy name — still accepted.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# If both Supabase env vars are empty, the frontend renders the
# /login page in "Supabase not configured" mode. In that case the
# backend should run with ALTERA_DEV_AUTH_ENABLED=true so the
# dashboard works against a synthetic dev user.
