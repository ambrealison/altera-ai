{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "uv",
      "runtimeArgs": [
        "run",
        "--directory",
        "apps/api",
        "uvicorn",
        "altera_api.main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "--filter",
        "@altera-ai/web",
        "dev"
      ],
      "port": 3000
    }
  ]
}
